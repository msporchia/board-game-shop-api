# HTTP server bind
PORT=3000                                   # port the service listens on
HOST=0.0.0.0                                # bind address

# Browser-facing
CORS_ORIGIN=http://localhost:5173           # allowed origin (the web app dev server)

# Upstream services (reached over the seller stack network)
SELLER_API_URL=http://seller-api:8000       # Python AI/RAG service (chat, search)

# Owned data
DB_PATH=./shop.db                           # SQLite database (catalog, orders, customers)
CATALOG_SEED_PATH=./data/sample-catalog.json # JSON snapshot seeding the catalog when empty
